---
interface Props {
  title: string;
  summary: string;
  client?: string;
  year: number;
  tags: string[];
  href: string;
  cover?: string;
  liveUrl?: string;
}

const { title, summary, client, year, tags, href, cover } = Astro.props;
---

<a href={href} class="group flex flex-col bg-(--card) border border-(--border) rounded-xl overflow-hidden hover:border-(--primary) transition-colors">
  <!-- Cover -->
  {cover ? (
    <img src={cover} alt={title} class="w-full aspect-video object-cover" />
  ) : (
    <div class="w-full aspect-video bg-(--muted) flex items-center justify-center">
      <span class="font-heading text-4xl font-bold text-(--border) select-none">
        {title.charAt(0)}
      </span>
    </div>
  )}

  <!-- Content -->
  <div class="flex flex-col flex-1 p-5 gap-3">
    <!-- Tags -->
    {tags.length > 0 && (
      <ul class="flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <li class="text-xs px-2 py-0.5 rounded-full border border-(--border) text-(--muted-foreground)">
            {tag}
          </li>
        ))}
      </ul>
    )}

    <!-- Title & summary -->
    <div class="flex flex-col gap-1.5 flex-1">
      <h3 class="font-heading font-semibold text-base leading-snug group-hover:text-(--primary) transition-colors">
        {title}
      </h3>
      <p class="text-sm text-(--muted-foreground) line-clamp-2">{summary}</p>
    </div>

    <!-- Client & year -->
    <p class="text-xs text-(--muted-foreground) mt-auto">
      {client && <span>{client} · </span>}{year}
    </p>
  </div>
</a>
