---
const navLinks = [
   { label: "Case Studies", href: "/case-studies/" },
   { label: "Blog", href: "/blog/" },
   { label: "Contact", href: "/#contact" },
];

const currentPath = Astro.url.pathname;
---

<header
   class='fixed top-0 left-0 right-0 z-50 border-b border-(--border) bg-(--background)/70 backdrop-blur-sm'
>
   <div class='max-w-6xl mx-auto px-4 sm:px-6 lg:px-8'>
      <div class='flex items-center justify-between h-16'>
         <a
            href='/'
            class='font-heading font-semibold text-lg tracking-tight hover:text-(--primary) transition-colors'
         >
            NP
         </a>

         <!-- Desktop nav -->
         <nav class='hidden md:flex items-center gap-8'>
            {
               navLinks.map(({ label, href }) => (
                  <a
                     href={href}
                     class:list={[
                        "text-sm transition-colors",
                        currentPath.startsWith(href) && href !== "/#contact"
                           ? "text-(--foreground) font-medium"
                           : "text-(--muted-foreground) hover:text-(--foreground)",
                     ]}
                  >
                     {label}
                  </a>
               ))
            }
         </nav>

         <!-- Mobile menu button -->
         <button
            id='mobile-menu-btn'
            aria-label='Open menu'
            class='md:hidden p-2 text-(--muted-foreground) hover:text-(--foreground) transition-colors'
         >
            <svg
               id='icon-open'
               width='20'
               height='20'
               viewBox='0 0 20 20'
               fill='none'
               stroke='currentColor'
               stroke-width='1.5'
            >
               <path stroke-linecap='round' d='M3 6h14M3 10h14M3 14h14'></path>
            </svg>
            <svg
               id='icon-close'
               class='hidden'
               width='20'
               height='20'
               viewBox='0 0 20 20'
               fill='none'
               stroke='currentColor'
               stroke-width='1.5'
            >
               <path stroke-linecap='round' d='M4 4l12 12M16 4L4 16'></path>
            </svg>
         </button>
      </div>
   </div>

   <!-- Mobile nav -->
   <div id='mobile-menu' class='hidden md:hidden border-t border-(--border)'>
      <nav class='max-w-6xl mx-auto px-4 py-4 flex flex-col gap-4'>
         {
            navLinks.map(({ label, href }) => (
               <a
                  href={href}
                  class='text-sm text-(--muted-foreground) hover:text-(--foreground) transition-colors'
               >
                  {label}
               </a>
            ))
         }
      </nav>
   </div>
</header>

<script>
   const btn = document.getElementById("mobile-menu-btn");
   const menu = document.getElementById("mobile-menu");
   const iconOpen = document.getElementById("icon-open");
   const iconClose = document.getElementById("icon-close");

   btn?.addEventListener("click", () => {
      const isOpen = !menu?.classList.contains("hidden");
      menu?.classList.toggle("hidden", isOpen);
      iconOpen?.classList.toggle("hidden", !isOpen);
      iconClose?.classList.toggle("hidden", isOpen);
   });
</script>
